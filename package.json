{
    "name": "cyastral_wiki",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate && next build",
        "start": "next start",
        "lint": "next lint",
        "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
        "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
        "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
        "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
        "db:check": "wrangler d1 migrations list cyastral-db --remote",
        "db:deploy": "wrangler d1 migrations apply cyastral-db --remote",
        "db:dev": "prisma migrate dev",
        "email:dev": "email dev"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1049.0",
        "@aws-sdk/s3-request-presigner": "^3.1049.0",
        "@hookform/resolvers": "^5.2.2",
        "@opennextjs/cloudflare": "^1.19.9",
        "@prisma/adapter-d1": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@tailwindcss/postcss": "^4.1.13",
        "better-auth": "^1.6.9",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.2.1",
        "input-otp": "^1.4.2",
        "lucide-react": "^0.544.0",
        "motion": "^12.23.26",
        "next": "16.2.6",
        "next-intl": "^4.11.2",
        "next-themes": "^0.4.6",
        "postcss": "^8.5.6",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-email": "6.4.0",
        "react-hook-form": "^7.65.0",
        "resend": "^6.12.4",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.3.1",
        "tailwindcss": "^4.1.13",
        "zod": "^4.1.12",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@react-email/ui": "6.4.0",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/browser": "^3.2.4",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9",
        "eslint-config-next": "15.3.2",
        "playwright": "^1.55.1",
        "prettier": "3.8.1",
        "prettier-plugin-tailwindcss": "0.7.2",
        "prisma": "^7.8.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5",
        "vitest": "^3.2.4",
        "wrangler": "^4.90.1"
    }
}
