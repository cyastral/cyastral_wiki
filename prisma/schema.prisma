generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Song{
  id          Int       @id @default(autoincrement())
  song_name   String    @unique
  singer      vcSinger[]
}

model vcSinger{
  id          Int       @id @default(autoincrement())
  name        String    @unique
  songs       Song[]
}
  