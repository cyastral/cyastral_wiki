generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Song {
  id        Int               @id @default(autoincrement())
  songName  String
  singers   VirtualSinger[]   @relation("SongToVirtualSinger")
  producers ProducerOnSongs[]
  links     Link[]
  coverUrl  String?
  audioUrl  String?
  source    String
  sourceId  String
  playlists PlaylistSong[]
}

model Link {
  id     Int    @id @default(autoincrement())
  url    String
  songId Int @map("songID")
  song   Song   @relation(fields: [songId], references: [id])
}

model VirtualSinger {
  id    Int    @id @default(autoincrement())
  name  String @unique
  songs Song[] @relation("SongToVirtualSinger")
}

model Producer {
  id    Int               @id @default(autoincrement())
  name  String
  songs ProducerOnSongs[]
}

model ProducerOnSongs {
  id         Int      @id @default(autoincrement())
  producer   Producer @relation(fields: [producerId], references: [id])
  producerId Int
  song       Song     @relation(fields: [songId], references: [id])
  songId     Int
}

model Playlist {
  id Int @id @default(autoincrement())
  title String
  isPublic Boolean @default(true)
  coverUrl String?

  songs PlaylistSong[]

  createAt DateTime @default(now())
  updateAt DateTime @updatedAt
}

model PlaylistSong {
  id Int @id @default(autoincrement())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId Int

  order Int
  addAt DateTime @default(now())

  song Song @relation(fields: [songId], references: [id] ,onDelete: Cascade)
  songId Int

  @@unique([playlistId, songId])
  @@index([playlistId])
}