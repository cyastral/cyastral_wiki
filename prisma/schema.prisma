generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Song {
  id        Int               @id @default(autoincrement())
  songName  String
  singers   VirtualSinger[]   @relation("SongToVirtualSinger")
  producers ProducerOnSongs[]
  links     Link[]
  coverUrl  String?
  audioUrl  String?
  source    String
  sourceId  String
}

model Link {
  id     Int    @id @default(autoincrement())
  url    String
  songId Int @map("songID")
  song   Song   @relation(fields: [songId], references: [id])
}

model VirtualSinger {
  id    Int    @id @default(autoincrement())
  name  String @unique
  songs Song[] @relation("SongToVirtualSinger")
}

model Producer {
  id    Int               @id @default(autoincrement())
  name  String
  songs ProducerOnSongs[]
}

model ProducerOnSongs {
  id         Int      @id @default(autoincrement())
  producer   Producer @relation(fields: [producerId], references: [id])
  producerId Int
  song       Song     @relation(fields: [songId], references: [id])
  songId     Int
}
